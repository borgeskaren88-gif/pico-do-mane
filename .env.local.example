# Copie este arquivo para .env.local (uso local) ou configure estas
# mesmas variáveis nas "Environment Variables" do projeto na Vercel.

# Encontradas em: Supabase → seu projeto → Project Settings → API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole-aqui-a-service-role-key

# Senha de acesso ao painel (escolha a sua)
APP_PASSWORD=Aurora@2809

# Uma frase secreta qualquer, só sua, usada para validar a sessão de login.
# Pode ser qualquer texto longo e aleatório - troque por algo próprio.
SESSION_SECRET=troque-por-um-texto-longo-e-aleatorio-so-seu
